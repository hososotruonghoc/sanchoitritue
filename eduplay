  for(var i=0;i<bs.length;i++){bs[i].style.cursor='default';bs[i].onclick=null;
    if(i===q.a){bs[i].className='ob dn ok';bs[i].children[0].textContent='✓'}
    else if(i===idx&&!ok){bs[i].className='ob dn no';bs[i].children[0].textContent='✕'}
    else bs[i].className='ob dn'}
  var fb=document.getElementById('qFeedback');fb.style.display='block';fb.className='fb '+(ok?'fok':'fno');
  fb.innerHTML='<span style="font-size:15px;font-weight:700;color:'+(ok?'#2e7d32':'#c62828')+'">'+pickRandom(ok?YAYS:NAYS)+(pts>0?' (+'+pts+' điểm)':'')+'</span>';
  setTimeout(function(){curSelected=-1;stopSpeaking();if(curIndex<curQuestions.length-1){curIndex++;showQuestion()}else finishQuiz()},voiceEnabled?2500:1500)
}

function forceEnd(){clearInterval(timerId);stopSpeaking();finishQuiz()}
function finishQuiz(){
  clearInterval(timerId);totalScore+=curScore;
  playCompleteSound();
  historyList.unshift({sub:curSubject,gr:playerGrade,sc:curScore,ok:curCorrect,tot:curQuestions.length,mc:curMaxCombo,dt:new Date().toLocaleDateString('vi-VN')});
  if(historyList.length>20)historyList.length=20;
  var r=getRank(totalScore),s=getSub(curSubject);
  document.getElementById('resEmoji').textContent=curCorrect>=12?'🏆':curCorrect>=8?'⭐':'💪';
  document.getElementById('resTitle').textContent=curCorrect>=12?'Xuất sắc!':curCorrect>=8?'Tốt lắm!':'Cố gắng hơn nhé!';
  document.getElementById('resSub').textContent=(s?s.n:'')+' • Lớp '+playerGrade+(playerClass?' '+playerClass:'');
  document.getElementById('resSc').textContent=curScore;document.getElementById('resOk').textContent=curCorrect+'/'+curQuestions.length;
  document.getElementById('resCb').textContent='x'+curMaxCombo;
  document.getElementById('resRk').textContent=r.i+' '+r.n+' — '+totalScore.toLocaleString()+' điểm';
  if(voiceEnabled && curSubject==='tienganh') setTimeout(function(){speakText('Result: You got '+curCorrect+' out of '+curQuestions.length+' correct! Score: '+curScore+' points.', 'en')},500);
  goPage('result')
}

function buildRanks(){
  var cur=getRank(totalScore),el=document.getElementById('ranksList');el.innerHTML='';
  for(var i=0;i<RANKS.length;i++){var r=RANKS[i],ic=(r.n===cur.n),gt=(totalScore>=r.m);
    el.innerHTML+='<div style="display:flex;align-items:center;gap:14px;padding:18px;border-radius:14px;border:'+(ic?'2px solid '+r.c:'1px solid rgba(0,0,0,.06)')+';background:'+(ic?r.c+'15':'rgba(255,255,255,.6)')+';margin-bottom:10px;opacity:'+(gt?'1':'.4')+';box-shadow:0 2px 8px rgba(0,0,0,.04)"><div style="width:48px;height:48px;border-radius:12px;background:'+(gt?r.c+'20':'#f5f5f5')+';display:flex;align-items:center;justify-content:center;font-size:26px">'+(gt?r.i:'🔒')+'</div><div style="flex:1"><div style="font-size:16px;font-weight:700;color:'+(gt?'#333':'#999')+'">'+r.n+(ic?' <span style="font-size:10px;padding:3px 8px;border-radius:5px;background:'+r.c+';color:#fff;font-weight:700">HIỆN TẠI</span>':'')+'</div><div style="font-size:12px;color:#999;margin-top:2px">Cần '+r.m.toLocaleString()+' điểm</div></div>'+(gt?'<span style="font-size:18px;color:#4CAF50">✓</span>':'')+'</div>'}
}

function buildHistory(){
  var el=document.getElementById('histList');
  if(!historyList.length){el.innerHTML='<div style="text-align:center;padding:60px 20px;color:#999"><div style="font-size:44px;margin-bottom:14px">📝</div><p style="font-size:15px">Chưa có lịch sử thi đấu nào.</p><p style="font-size:13px;margin-top:6px">Hãy bắt đầu thi đấu ngay!</p></div>';return}
  el.innerHTML='';
  for(var i=0;i<historyList.length;i++){var h=historyList[i],s=getSub(h.sub),pc=Math.round(h.ok/h.tot*100);
    el.innerHTML+='<div style="display:flex;align-items:center;gap:12px;padding:16px;border-radius:12px;background:rgba(255,255,255,.6);border:1px solid rgba(0,0,0,.05);margin-bottom:8px;box-shadow:0 2px 6px rgba(0,0,0,.03)"><div style="width:44px;height:44px;border-radius:11px;background:'+(s?s.gd:'#eee')+';display:flex;align-items:center;justify-content:center;font-size:20px">'+(s?s.ic:'')+'</div><div style="flex:1"><div style="font-size:14px;font-weight:600;color:#333">'+(s?s.n:'')+' • Lớp '+h.gr+'</div><div style="font-size:11px;color:#999;margin-top:2px">'+h.ok+'/'+h.tot+' đúng ('+pc+'%) • 🔥 Combo x'+h.mc+' • '+h.dt+'</div></div><div style="font-size:16px;font-weight:800;color:'+(pc>=80?'#4CAF50':pc>=50?'#FF9800':'#f44336')+'">+'+h.sc+'</div></div>'}
}

buildGrades();
</script>
</body>
</html>
