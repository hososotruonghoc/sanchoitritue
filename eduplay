<script>
// ===== SOUND EFFECTS (Web Audio API) =====
var soundEnabled = true;
var audioCtx = null;

function getAudioCtx(){
  if(!audioCtx){try{audioCtx=new(window.AudioContext||window.webkitAudioContext)()}catch(e){soundEnabled=false}}
  return audioCtx;
}

function playTone(freq, duration, type, vol){
  if(!soundEnabled)return;
  var ctx=getAudioCtx();if(!ctx)return;
  var osc=ctx.createOscillator();var gain=ctx.createGain();
  osc.connect(gain);gain.connect(ctx.destination);
  osc.type=type||'sine';osc.frequency.value=freq;
  gain.gain.value=vol||0.15;
  gain.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+duration);
  osc.start(ctx.currentTime);osc.stop(ctx.currentTime+duration);
}

function playCorrectSound(){
  if(!soundEnabled)return;
  // Happy ascending C-E-G arpeggio
  setTimeout(function(){playTone(523,0.15,'sine',0.12)},0);
  setTimeout(function(){playTone(659,0.15,'sine',0.12)},100);
  setTimeout(function(){playTone(784,0.25,'sine',0.15)},200);
}

function playWrongSound(){
  if(!soundEnabled)return;
  // Gentle descending tone
  setTimeout(function(){playTone(350,0.2,'triangle',0.1)},0);
  setTimeout(function(){playTone(280,0.3,'triangle',0.08)},150);
}

function playCompleteSound(){
  if(!soundEnabled)return;
  // Fanfare: C-E-G-C
  setTimeout(function(){playTone(523,0.2,'sine',0.12)},0);
  setTimeout(function(){playTone(659,0.2,'sine',0.12)},150);
  setTimeout(function(){playTone(784,0.2,'sine',0.12)},300);
  setTimeout(function(){playTone(1047,0.4,'sine',0.15)},450);
}

function toggleSound(){
  soundEnabled=!soundEnabled;
  document.getElementById('soundBtn').textContent=soundEnabled?'🔊':'🔇';
}

// ===== TEXT-TO-SPEECH (Google Translate - Giọng Việt chuẩn) =====
var voiceEnabled = false;
var ttsQueue = [];
var ttsPlaying = false;
var currentAudio = null;

// Dùng Google Translate TTS - giọng nữ Việt Nam chuẩn, không cần cài đặt
function gttsSpeak(text, lang, onEnd){
  var maxLen = 180;
  // Chia nhỏ text nếu quá dài
  var chunks = [];
  if(text.length <= maxLen){
    chunks.push(text);
  } else {
    var sentences = text.split(/(?<=[.?!,;:])\s*/);
    var buf = '';
    for(var i=0;i<sentences.length;i++){
      if((buf + ' ' + sentences[i]).length > maxLen && buf.length > 0){
        chunks.push(buf.trim());
        buf = sentences[i];
      } else {
        buf = buf ? buf + ' ' + sentences[i] : sentences[i];
      }
    }
    if(buf.trim()) chunks.push(buf.trim());
  }

  var idx = 0;
  function playNext(){
    if(idx >= chunks.length){ if(onEnd) onEnd(); return; }
    var url = 'https://translate.google.com/translate_tts?ie=UTF-8&client=tw-ob&tl='
      + encodeURIComponent(lang) + '&q=' + encodeURIComponent(chunks[idx]);
    var audio = new Audio(url);
    currentAudio = audio;
    // Tăng tốc độ phát nhẹ để giọng nghe cao hơn, trẻ hơn
    audio.playbackRate = lang === 'vi' ? 1.08 : 1.05;
    audio.onended = function(){ idx++; playNext(); };
    audio.onerror = function(){
      console.log('TTS error, trying Web Speech fallback');
      webSpeechFallback(chunks.slice(idx).join('. '), lang, onEnd);
    };
    audio.play().catch(function(e){
      console.log('Audio play blocked:', e);
      webSpeechFallback(chunks.slice(idx).join('. '), lang, onEnd);
    });
  }
  playNext();
}

// Fallback: dùng Web Speech API nếu Google TTS không được
function webSpeechFallback(text, lang, onEnd){
  var synth = window.speechSynthesis;
  if(!synth){ if(onEnd) onEnd(); return; }
  synth.cancel();
  var utter = new SpeechSynthesisUtterance(text);
  utter.lang = lang === 'en' ? 'en-US' : 'vi-VN';
  utter.rate = 0.85;
  utter.pitch = 1.5;
  // Tìm voice phù hợp
  var voices = synth.getVoices();
  for(var i=0;i<voices.length;i++){
    var vl = (voices[i].lang||'').toLowerCase().replace('_','-');
    if(lang==='en' && vl.indexOf('en')===0){ utter.voice=voices[i]; break; }
    if(lang==='vi' && vl.indexOf('vi')===0){ utter.voice=voices[i]; break; }
  }
  utter.onend = onEnd;
  synth.speak(utter);
}

function stopSpeaking(){
  if(currentAudio){ currentAudio.pause(); currentAudio=null; }
  if(window.speechSynthesis) window.speechSynthesis.cancel();
}

function speakText(text, lang){
  if(!voiceEnabled) return;
  stopSpeaking();
  gttsSpeak(text, lang || 'vi');
}

function getQuizLang(){ return (curSubject==='tienganh') ? 'en' : 'vi'; }

function readQuestion(){
  var q=curQuestions[curIndex], lang=getQuizLang();
  var text='', labels=['A','B','C','D'];
  if(lang==='en'){
    text='Question '+(curIndex+1)+'. '+q.q;
    for(var i=0;i<q.o.length;i++) text+='. '+labels[i]+': '+q.o[i];
  } else {
    text='Câu '+(curIndex+1)+'. '+q.q;
    for(var i=0;i<q.o.length;i++) text+='. Đáp án '+labels[i]+': '+q.o[i];
  }
  var w=voiceEnabled; voiceEnabled=true;
  speakText(text, lang);
  voiceEnabled=w;
}

function toggleVoice(){
  voiceEnabled = !voiceEnabled;
  var btn = document.getElementById('voiceBtn');
  btn.textContent = voiceEnabled ? '🎤 Đang đọc' : '🎤 Giọng đọc';
  btn.style.background = voiceEnabled ? '#e3f2fd' : 'rgba(255,255,255,.8)';
  btn.style.color = voiceEnabled ? '#1565c0' : '#666';
  btn.style.borderColor = voiceEnabled ? '#90caf9' : 'rgba(0,0,0,.08)';
  if(!voiceEnabled) stopSpeaking();
  if(voiceEnabled){
    speakText('Voice reading is on!', 'en');
  }
}
